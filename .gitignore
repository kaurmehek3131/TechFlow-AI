# ===========================================
# TechFlow AI - Root .gitignore
# ===========================================

# Environment variables (CRITICAL - never commit these)
.env
.env.*
!.env.example
.dev.vars

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
dist-ssr/
.output/
.vinxi/
.nitro/
.tanstack/

# Wrangler / Cloudflare
.wrangler/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor directories
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Lock files (optional - uncomment if you want to ignore)
# bun.lock
# package-lock.json

# Logs
logs/
*.log
